# Workspace + runtime
ASSISTANT_MAX_ITERATIONS=8
ASSISTANT_MAX_TASK_ATTEMPTS=2
ASSISTANT_MAX_TOOL_STEPS=4

# OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REASONING_MODEL=gpt-4.1-mini
OPENAI_CODE_MODEL=gpt-4.1-mini
OPENAI_SYNTHESIS_MODEL=gpt-4.1-mini

# Anthropic provider
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_REASONING_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_SYNTHESIS_MODEL=claude-3-5-sonnet-latest

# Optional Brave Search API for higher quality web results
BRAVE_SEARCH_API_KEY=

